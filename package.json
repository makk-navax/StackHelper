{
  "name": "stackhelper",
  "displayName": "StackHelper",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "stackhelper",
          "title": "Stack Helper",
          "icon": "resource/stack.png"
        }
      ]
    },
    "views": {
      "stackhelper": [
        {
          "id": "stackhelper-view",
          "name": "Stack Helper",
          "type": "webview",
          "icon": ""
        },
        {
          "id": "stackhelper-callstack",
          "name": "Call Stack",
          "type": "webview",
          "icon": ""
        }
      ]
    },
    "commands": [
      {
        "command": "stackhelper.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "7zip-min": "^3.0.1",
    "adm-zip": "^0.5.16"
  }
}
